{
  "name": "mooshtaba-bot",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail",
    "d1:create": "wrangler d1 create mooshtaba-db",
    "d1:migrate": "wrangler d1 execute mooshtaba-db --file=src/db/schema.sql"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20240923.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "wrangler": "^3.114.17"
  }
}
